datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  TRAINER
}

enum PlanType {
  REGULAR
  ONE_TO_ONE
}

enum StudentLevel {
  BEGINNER
  FOUNDATION_1
  FOUNDATION_2
  FOUNDATION_3
  NATIONAL_4
  NATIONAL_5
  NATIONAL_6
  NATIONAL_7
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(TRAINER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id             String        @id @default(cuid())
  studentNumber  Int           @unique
  name           String
  dateOfBirth    DateTime
  gender         String
  parentName     String
  contactNumber  String
  admissionDate  DateTime      @default(now())
  notes          String?
  medicalHistory String?
  avatarUrl      String?
  level          StudentLevel  @default(BEGINNER)
  password       String?
  isTempPassword Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  plans          StudentPlan[]
  attendances    Attendance[]
  payments       PaymentRecord[]
}

model SessionPricing {
  id              String   @id @default(cuid())
  planType        PlanType
  daysPerWeek     Int
  pricePerSession Int
  updatedAt       DateTime @updatedAt

  @@unique([planType, daysPerWeek])
}

model PlanTemplate {
  id             String   @id @default(cuid())
  name           String
  planType       PlanType @default(REGULAR)
  durationMonths Int?
  totalSessions  Int?
  validityDays   Int?
  defaultFee     Int?
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Batch {
  id           String        @id @default(cuid())
  name         String
  /// Human-readable timing string, e.g. "7:00 AM – 8:00 AM"
  timing       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  studentPlans StudentPlan[]
}

model StudentPlan {
  id                String       @id @default(cuid())
  studentId         String
  student           Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  /// Optional batch assignment. SetNull on batch deletion.
  batchId           String?
  batch             Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  /// Optional coach assignment — only used for ONE_TO_ONE plans.
  coachId           String?
  coach             Coach?       @relation(fields: [coachId], references: [id], onDelete: SetNull)
  planType          PlanType
  startDate         DateTime
  endDate           DateTime
  selectedDays      Json
  sessionsPerWeek   Int
  discountPercent   Float        @default(0)
  totalSessions     Int
  validityDays      Int
  /// Grace-period deadline = endDate + graceDays (stored at plan creation).
  /// Use this to derive GRACE vs INACTIVE status.
  expiryDate        DateTime
  /// Number of grace days granted when this plan was created.
  graceDays         Int          @default(0)
  fee               Int
  pricePerSession   Int
  sessionsCompleted Int          @default(0)
  planMonths        Int?
  isActive          Boolean      @default(true)
  /// When set, the plan is frozen (holiday). Status = FREEZE.
  freezeStartDate   DateTime?
  /// End of the current freeze window.
  freezeEndDate     DateTime?
  freezePeriods     FreezePeriod[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  attendances       Attendance[]
  payments          PaymentRecord[]

  @@index([studentId])
  @@index([studentId, isActive])
  @@index([batchId])
  @@index([coachId])
}

model FreezePeriod {
  id            String      @id @default(cuid())
  studentPlanId String
  studentPlan   StudentPlan @relation(fields: [studentPlanId], references: [id], onDelete: Cascade)
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([studentPlanId])
}

/// Admin-configurable grace period days per (sessionsPerWeek × planMonths) combination.
/// Falls back to formula (sessionsPerWeek × planMonths × 2) if no row exists.
model GracePeriodSettings {
  id              String   @id @default(cuid())
  sessionsPerWeek Int
  /// 1 = 1-month plan, 3 = 3-month plan, 0 = catch-all / no grace
  planMonths      Int
  graceDays       Int      @default(0)
  updatedAt       DateTime @updatedAt

  @@unique([sessionsPerWeek, planMonths])
}

model Attendance {
  id            String      @id @default(cuid())
  studentId     String
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentPlanId String
  studentPlan   StudentPlan @relation(fields: [studentPlanId], references: [id], onDelete: Cascade)
  date          DateTime    @db.Date
  markedById    String?
  createdAt     DateTime    @default(now())

  @@unique([studentId, date])
  @@index([studentPlanId])
}

enum PaymentMethod {
  UPI
  CASH
  BANK_TRANSFER
  OTHER
}

enum EnquiryStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  CONVERTED
  LOST
}

model Enquiry {
  id              String        @id @default(cuid())
  enquiryNumber   Int           @unique
  childName       String
  childAge        Int?
  gender          String?
  parentName      String
  contactNumber   String
  source          String?
  interestedIn    String?
  status          EnquiryStatus @default(NEW)
  notes           String?
  followUpDate    DateTime?
  convertedToId   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PaymentRecord {
  id            String        @id @default(cuid())
  invoiceNumber Int           @unique @default(autoincrement())
  studentPlanId String
  studentPlan   StudentPlan   @relation(fields: [studentPlanId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount        Int
  method        PaymentMethod @default(CASH)
  notes         String?
  paidAt        DateTime      @default(now())
  createdAt     DateTime      @default(now())

  @@index([studentId])
  @@index([studentPlanId])
}

model AcademyProfile {
  id        String   @id @default(cuid())
  email     String?
  phone     String?
  phone2    String?
  address   String?
  website   String?
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Coach models
// ─────────────────────────────────────────────

enum CoachStatus {
  WORKING
  LEFT
}

enum CoachRole {
  COACH
  STAFF
}

enum CoachAttendanceStatus {
  PRESENT
  ABSENT
}

model Coach {
  id             String               @id @default(cuid())
  name           String
  contactNumber  String
  email          String?
  joinDate       DateTime
  /// Human-readable timing string, e.g. "7:00 AM – 9:00 AM"
  timing         String?
  specialization String?
  /// Monthly fixed salary in ₹
  fixedSalary    Int                  @default(0)
  status         CoachStatus          @default(WORKING)
  role           CoachRole            @default(COACH)
  notes          String?
  address        String?
  avatarUrl      String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  attendances    CoachAttendance[]
  /// ONE_TO_ONE student plans assigned to this coach
  studentPlans   StudentPlan[]
  salaryPayments CoachSalaryPayment[]
}

model CoachAttendance {
  id        String                @id @default(cuid())
  coachId   String
  coach     Coach                 @relation(fields: [coachId], references: [id], onDelete: Cascade)
  date      DateTime              @db.Date
  status    CoachAttendanceStatus
  createdAt DateTime              @default(now())

  @@unique([coachId, date])
  @@index([coachId])
}

model CoachSalaryPayment {
  id        String    @id @default(cuid())
  coachId   String
  coach     Coach     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  year      Int
  month     Int
  amount    Int
  paid      Boolean   @default(false)
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([coachId, year, month])
  @@index([coachId])
}
