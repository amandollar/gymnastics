datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  TRAINER
}

enum PlanType {
  REGULAR
  ONE_TO_ONE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(TRAINER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id             String        @id @default(cuid())
  studentNumber  Int           @unique
  name           String
  dateOfBirth    DateTime
  gender         String
  parentName     String
  contactNumber  String
  admissionDate  DateTime      @default(now())
  notes          String?
  medicalHistory String?
  avatarUrl      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  plans          StudentPlan[]
  attendances    Attendance[]
}

model SessionPricing {
  id              String   @id @default(cuid())
  planType        PlanType
  daysPerWeek     Int
  pricePerSession Int
  updatedAt       DateTime @updatedAt

  @@unique([planType, daysPerWeek])
}

model PlanTemplate {
  id             String   @id @default(cuid())
  name           String
  planType       PlanType @default(REGULAR)
  durationMonths Int?
  totalSessions  Int?
  validityDays   Int?
  defaultFee     Int?
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Batch {
  id           String        @id @default(cuid())
  name         String
  /// Human-readable timing string, e.g. "7:00 AM – 8:00 AM"
  timing       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  studentPlans StudentPlan[]
}

model StudentPlan {
  id                String       @id @default(cuid())
  studentId         String
  student           Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  /// Optional batch assignment. SetNull on batch deletion.
  batchId           String?
  batch             Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  planType          PlanType
  startDate         DateTime
  endDate           DateTime
  selectedDays      Json
  sessionsPerWeek   Int
  discountPercent   Float        @default(0)
  totalSessions     Int
  validityDays      Int
  /// Grace-period deadline = endDate + graceDays (stored at plan creation).
  /// Use this to derive GRACE vs INACTIVE status.
  expiryDate        DateTime
  /// Number of grace days granted when this plan was created.
  graceDays         Int          @default(0)
  fee               Int
  pricePerSession   Int
  sessionsCompleted Int          @default(0)
  planMonths        Int?
  isActive          Boolean      @default(true)
  /// When set, the plan is frozen (holiday). Status = FREEZE.
  freezeStartDate   DateTime?
  /// End of the current freeze window.
  freezeEndDate     DateTime?
  freezePeriods     FreezePeriod[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  attendances       Attendance[]

  @@index([studentId])
  @@index([studentId, isActive])
  @@index([batchId])
}

model FreezePeriod {
  id            String      @id @default(cuid())
  studentPlanId String
  studentPlan   StudentPlan @relation(fields: [studentPlanId], references: [id], onDelete: Cascade)
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([studentPlanId])
}

/// Admin-configurable grace period days per (sessionsPerWeek × planMonths) combination.
/// Falls back to formula (sessionsPerWeek × planMonths × 2) if no row exists.
model GracePeriodSettings {
  id              String   @id @default(cuid())
  sessionsPerWeek Int
  /// 1 = 1-month plan, 3 = 3-month plan, 0 = catch-all / no grace
  planMonths      Int
  graceDays       Int      @default(0)
  updatedAt       DateTime @updatedAt

  @@unique([sessionsPerWeek, planMonths])
}

model Attendance {
  id            String      @id @default(cuid())
  studentId     String
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentPlanId String
  studentPlan   StudentPlan @relation(fields: [studentPlanId], references: [id], onDelete: Cascade)
  date          DateTime    @db.Date
  markedById    String?
  createdAt     DateTime    @default(now())

  @@unique([studentId, date])
  @@index([studentPlanId])
}

enum EnquiryStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  CONVERTED
  LOST
}

model Enquiry {
  id              String        @id @default(cuid())
  enquiryNumber   Int           @unique
  childName       String
  childAge        Int?
  gender          String?
  parentName      String
  contactNumber   String
  source          String?
  interestedIn    String?
  status          EnquiryStatus @default(NEW)
  notes           String?
  followUpDate    DateTime?
  convertedToId   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
