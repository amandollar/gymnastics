# Database Connection 
# Use the pooled connection string from Neon. sslmode=verify-full is set automatically
# in code; you can also append it yourself:
# postgresql://user:pass@host/db?sslmode=verify-full
DATABASE_URL=

# NextAuth Configuration
# Run `openssl rand -base64 32` or use a secure random string
NEXTAUTH_SECRET="f6c8d9e2b10a4c5d8e9f0a1b2c3d4e5f"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (student profile photos — optional until you upload real images)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Optional folder prefix inside your Cloudinary account
CLOUDINARY_FOLDER="tag-crm/students"

# Admin Seeding Credentials (used by seed.ts)
ADMIN_SEED_EMAIL="admin@academyofgymnast.com"
ADMIN_SEED_PASSWORD="AdminPassword123!"

